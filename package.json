{
  "name": "pokedash",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Competitive Pokemon Champions dashboard",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "data:refresh": "tsx scripts/build-meta-json.ts && tsx scripts/enrich-pokedex.ts && tsx scripts/enrich-megas.ts",
    "data:refresh:sample": "tsx scripts/build-meta-json.ts --top-20",
    "data:enrich-pokedex": "tsx scripts/enrich-pokedex.ts",
    "data:enrich-megas": "tsx scripts/enrich-megas.ts"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "cheerio": "^1.2.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0"
  }
}
